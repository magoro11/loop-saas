# Copy to .env.local and fill in values for local development
# Supabase database connection (get this from Supabase Dashboard > Settings > Database)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# For connection pooling (recommended for serverless/Next.js), use port 6543:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres"

NEXTAUTH_SECRET=replace_me
NEXTAUTH_URL=http://localhost:3000
ANTHROPIC_API_KEY=replace_me
EMBEDDING_API_KEY=replace_me
