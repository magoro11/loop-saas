# Copy to .env.local and fill in values for local development
# Neon direct connection (recommended for local dev)
DATABASE_URL="postgresql://neondb_owner:[YOUR-PASSWORD]@ep-[YOUR-PROJECT-REF].c-[REGION].aws.neon.tech/neondb?sslmode=require"

# For connection pooling (serverless/Next.js), use the -pooler endpoint on port 5432 or 6543:
# DATABASE_URL="postgresql://neondb_owner:[YOUR-PASSWORD]@ep-[YOUR-PROJECT-REF]-pooler.c-[REGION].aws.neon.tech:6543/neondb?sslmode=require"

NEXTAUTH_SECRET=replace_me
NEXTAUTH_URL=http://localhost:3000
ANTHROPIC_API_KEY=replace_me

# Real embeddings provider (OpenAI text-embedding-3-small). Falls back to deterministic vectors if unset.
OPENAI_API_KEY=replace_me
# EMBEDDING_API_KEY is also accepted as an alias for OPENAI_API_KEY
